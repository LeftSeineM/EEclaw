{
  "name": "ee-info",
  "version": "0.1.1",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "clean:dist": "node scripts/clean-for-dist.js",
    "build:exe": "npm run clean:dist && npm run build && electron-builder --win portable",
    "start": "cross-env NODE_ENV=production electron ."
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "iconv-lite": "^0.7.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sm-crypto": "^0.3.14"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react-swc": "^3.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.0",
    "electron": "^29.0.0",
    "electron-builder": "^25.0.0",
    "electron-reload": "^2.0.0-alpha.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.eeinfo.app",
    "productName": "EEclaw",
    "directories": {
      "output": "../桌面端版本更新"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": null,
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "EEclaw_v${version}.exe"
    }
  }
}
